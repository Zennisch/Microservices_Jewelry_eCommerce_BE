FROM openjdk:17-jdk-slim

WORKDIR /app

RUN apt-get update && \
    apt-get install -y curl unzip && \
    rm -rf /var/lib/apt/lists/*

COPY build.gradle.kts settings.gradle.kts gradlew ./
COPY gradle gradle/
RUN chmod +x gradlew

RUN ./gradlew dependencies --no-daemon

COPY . .

EXPOSE 8001

CMD ["./gradlew", "bootRun", "--no-daemon"]